<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Sussudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Sussudio"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Simple Sussudio">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="0" RowSpacing="0">
        <Grid.Resources>
            <Storyboard x:Name="RecPulseStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="RecIndicatorDot"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.3"
                                 Duration="0:0:0.8"
                                 AutoReverse="True"/>
            </Storyboard>
            <Storyboard x:Name="RecordingGlowPulseStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="RecordingGlowBorder"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.5"
                                 Duration="0:0:0.75"
                                 AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="StatsDockColumn" Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- Row 0: Preview -->
            <RowDefinition Height="Auto"/>   <!-- Row 1: Settings Shelf -->
            <RowDefinition Height="Auto"/>   <!-- Row 2: Flashback Timeline -->
            <RowDefinition Height="Auto"/>   <!-- Row 3: Control Bar -->
        </Grid.RowDefinitions>

        <!-- Row 0: Preview Area + Settings Overlay -->
        <Grid Grid.Row="0" Grid.Column="0" ColumnSpacing="0">
            <!-- Composition DropShadow — behind PreviewBorder, casts onto app background -->
            <Border x:Name="VideoShadowHost" Grid.Column="0"
                    Background="Transparent"
                    IsHitTestVisible="False"/>

            <!-- Preview Border -->
            <Border x:Name="PreviewBorder" Grid.Column="0"
                    AutomationProperties.AutomationId="PreviewBorder"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    Margin="12,6,12,6"
                    RenderTransformOrigin="0.5,0.5"
                    DoubleTapped="PreviewBorder_DoubleTapped">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="FullScreenMenuItem"
                                        Text="Enter Full Screen"
                                        Click="FullScreenMenuItem_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE740;"/>
                            </MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAcceleratorTextOverride>F11</MenuFlyoutItem.KeyboardAcceleratorTextOverride>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Border.ContextFlyout>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="PreviewBorderScale"
                                    ScaleX="1"
                                    ScaleY="1"/>
                </Border.RenderTransform>
                <Grid>
                    <Border x:Name="PreviewShadowHost"
                            Margin="16"
                            CornerRadius="4"
                            Background="Transparent">
                    <Grid x:Name="PreviewContentGrid"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="PreviewContentScale"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </Grid.RenderTransform>
                    <Border x:Name="PreviewLetterboxBackground"
                            Background="Black"
                            Visibility="Collapsed" />

                    <!-- Primary GPU preview path -->
                    <SwapChainPanel x:Name="PreviewSwapChainPanel"
                                    AutomationProperties.AutomationId="PreviewPlayerElement"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />

                    <!-- Fallback CPU preview path -->
                    <Image x:Name="PreviewImage"
                           AutomationProperties.AutomationId="PreviewImage"
                           Stretch="Uniform"
                           Visibility="Collapsed"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>

                    <!-- Recording Indicator (hidden — glow border serves as tally) -->
                    <Border x:Name="RecordingIndicator"
                            AutomationProperties.AutomationId="RecordingIndicator"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="16,12,0,0"
                            Padding="8,4"
                            CornerRadius="4"
                            Background="{ThemeResource RecordingIndicatorBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse x:Name="RecIndicatorDot" Width="10" Height="10" Fill="White"/>
                            <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="RecordingGlowBorder"
                            BorderThickness="3"
                            BorderBrush="#50FF1414"
                            Opacity="0"
                            IsHitTestVisible="False"/>

                    <Border x:Name="FrameTimeOverlay"
                            AutomationProperties.AutomationId="FrameTimeOverlay"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Margin="14,14,14,0"
                            MaxWidth="520"
                            Padding="10"
                            CornerRadius="6"
                            Background="#CC080808"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1">
                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="92" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FrameTime_SourceValue" AutomationProperties.AutomationId="FrameTime_SourceValue" Text="Source —" Foreground="#DDEDEDED" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="FrameTime_VisualValue" AutomationProperties.AutomationId="FrameTime_VisualValue" Grid.Column="1" Text="Visual —" Foreground="#DDEDEDED" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="FrameTime_PreviewValue" AutomationProperties.AutomationId="FrameTime_PreviewValue" Grid.Column="2" Text="Preview —" Foreground="#DDEDEDED" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="FrameTime_LatencyValue" AutomationProperties.AutomationId="FrameTime_LatencyValue" Grid.Column="3" Text="Latency —" Foreground="#DDEDEDED" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Canvas x:Name="FrameTime_Canvas"
                                    AutomationProperties.AutomationId="FrameTime_Canvas"
                                    Grid.Row="1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <Polyline x:Name="FrameTime_VisualLine"
                                          Stroke="#55D6FF"
                                          StrokeThickness="2" />
                                <Polyline x:Name="FrameTime_PreviewLine"
                                          Stroke="#70F08B"
                                          StrokeThickness="2" />
                                <Line x:Name="FrameTime_ExpectedLine"
                                      X1="0"
                                      Y1="46"
                                      X2="500"
                                      Y2="46"
                                      Stroke="#33FFFFFF"
                                      StrokeThickness="1" />
                            </Canvas>
                            <TextBlock x:Name="FrameTime_StatusValue"
                                       AutomationProperties.AutomationId="FrameTime_StatusValue"
                                       Grid.Row="2"
                                       Text="Blue=visual changes  Green=preview presents"
                                       Foreground="#99FFFFFF"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                    </Grid>
                    </Border>

                    <!-- No Device Placeholder -->
                    <StackPanel x:Name="NoDevicePlaceholder"
                                AutomationProperties.AutomationId="NoDevicePlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <FontIcon Glyph="&#xE714;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="Preview is off"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Open settings to select a device, then click Start Preview"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Preview Loading Overlay -->
                    <StackPanel x:Name="PreviewLoadingOverlay"
                                AutomationProperties.AutomationId="PreviewLoadingOverlay"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12">
                        <ProgressRing IsActive="False" Width="40" Height="40"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Disk warning InfoBar — overlays at top of preview area -->
            <InfoBar x:Name="DiskWarningInfoBar"
                     AutomationProperties.AutomationId="DiskWarningInfoBar"
                     Title="Disk Space Warning"
                     Message="Recording disk usage exceeds the flashback buffer limit. Oldest segments cannot be evicted."
                     Severity="Error"
                     IsOpen="False"
                     IsClosable="False"
                     VerticalAlignment="Top"
                     Margin="16,8,16,0"/>

        </Grid>

        <!-- Stats Dock Panel — full-height right column, outside preview grid -->
        <Border x:Name="StatsDockPanel"
                AutomationProperties.AutomationId="StatsDockPanel"
                Grid.Column="1"
                Grid.RowSpan="4"
                Visibility="Collapsed"
                Width="0"
                MaxWidth="360"
                Margin="0,8,12,16"
                    Padding="12"
                    BorderThickness="0"
                    CornerRadius="8">
                <Border.Background>
                    <AcrylicBrush TintColor="#0A0A0A"
                                  TintOpacity="0.80"
                                  FallbackColor="#141414"/>
                </Border.Background>
                <Border.Resources>
                    <Style x:Key="DockStatsLabelStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="DockStatsValueStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontFamily" Value="Consolas" />
                        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style x:Key="DockStatsSectionHeaderStyle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Style>
                    <Style x:Key="DockStatsRowStyle" TargetType="Border">
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                    <Style x:Key="DockStatsRowAltStyle" TargetType="Border">
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="CornerRadius" Value="4" />
                        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                    </Style>
                </Border.Resources>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="StatsDockTranslate" X="0"/>
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,14,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Stats"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <TextBlock x:Name="Stats_SessionStateValue"
                                   AutomationProperties.AutomationId="Stats_SessionStateValue"
                                   Text="Idle"
                                   Style="{StaticResource DockStatsLabelStyle}" />

                        <StackPanel Spacing="2">
                            <TextBlock Text="Live Summary" Style="{StaticResource DockStatsSectionHeaderStyle}" Margin="0,0,0,4" />
                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Capture" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SummaryCaptureValue" AutomationProperties.AutomationId="Stats_SummaryCaptureValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Preview" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SummaryPreviewValue" AutomationProperties.AutomationId="Stats_SummaryPreviewValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Preview Cadence" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SummaryRendererFpsValue" AutomationProperties.AutomationId="Stats_SummaryRendererFpsValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="NoWrap" MaxLines="1" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Visual Repeat" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SummaryVisualFpsValue" AutomationProperties.AutomationId="Stats_SummaryVisualFpsValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Latency" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SummaryLatencyValue" AutomationProperties.AutomationId="Stats_SummaryLatencyValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="SourceSignal_Header" AutomationProperties.AutomationId="SourceSignal_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="SourceSignal_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HDMI Input" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="SourceSignal_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="SourceSignal_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Resolution" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SourceResolutionValue" AutomationProperties.AutomationId="Stats_SourceResolutionValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame Rate" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SourceFrameRateValue" AutomationProperties.AutomationId="Stats_SourceFrameRateValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HDR" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SourceHdrValue" AutomationProperties.AutomationId="Stats_SourceHdrValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Video Format" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SourceFormatValue" AutomationProperties.AutomationId="Stats_SourceFormatValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Telemetry" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_TelemetryOriginValue" AutomationProperties.AutomationId="Stats_TelemetryOriginValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ADC" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_AdcOnOffValue" AutomationProperties.AutomationId="Stats_AdcOnOffValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Analog Gain" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_AdcGainValue" AutomationProperties.AutomationId="Stats_AdcGainValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="EncoderSection" Spacing="2" Visibility="Collapsed">
                            <TextBlock Text="Encoder" Style="{StaticResource DockStatsSectionHeaderStyle}" Margin="0,0,0,4" />
                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Codec" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_EncoderCodecValue" AutomationProperties.AutomationId="Stats_EncoderCodecValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Resolution" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_EncoderResolutionValue" AutomationProperties.AutomationId="Stats_EncoderResolutionValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame Rate" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_EncoderFrameRateValue" AutomationProperties.AutomationId="Stats_EncoderFrameRateValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Target Bitrate" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_EncoderBitrateValue" AutomationProperties.AutomationId="Stats_EncoderBitrateValue" Grid.Column="1" Text="—" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="SourceCadence_Header" AutomationProperties.AutomationId="SourceCadence_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="SourceCadence_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Capture Frame Time" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="SourceCadence_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="SourceCadence_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Average Rate" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_SourceFpsValue" AutomationProperties.AutomationId="Stats_SourceFpsValue" Text="0.00" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock Text="/" Style="{StaticResource DockStatsLabelStyle}" />
                                        <TextBlock x:Name="Stats_SourceExpectedFpsValue" AutomationProperties.AutomationId="Stats_SourceExpectedFpsValue" Text="0.00" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock Text="expected" Style="{StaticResource DockStatsLabelStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame Time" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_SourceAvgValue" AutomationProperties.AutomationId="Stats_SourceAvgValue" Text="0.00ms avg" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_SourceP95Value" AutomationProperties.AutomationId="Stats_SourceP95Value" Text="0.00ms P95" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Jitter" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_SourceJitterValue" AutomationProperties.AutomationId="Stats_SourceJitterValue" Grid.Column="1" Text="0.00ms" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Gaps" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_SourceGapsValue" AutomationProperties.AutomationId="Stats_SourceGapsValue" Text="0 severe" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_SourceDropsValue" AutomationProperties.AutomationId="Stats_SourceDropsValue" Text="0 drops (0.0%)" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="DecodeSection" Spacing="2" Visibility="Collapsed">
                            <Grid x:Name="Decode_Header" AutomationProperties.AutomationId="Decode_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="Decode_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MJPEG Decode" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="Decode_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel x:Name="Decode_Content" Spacing="2" />
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="PreviewCadence_Header" AutomationProperties.AutomationId="PreviewCadence_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="PreviewCadence_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Preview Frame Time" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="PreviewCadence_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="PreviewCadence_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Average Rate" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_PreviewFpsValue" AutomationProperties.AutomationId="Stats_PreviewFpsValue" Grid.Column="1" Text="0.00" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame Time" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_PreviewAvgValue" AutomationProperties.AutomationId="Stats_PreviewAvgValue" Text="0.00ms avg" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_PreviewP95Value" AutomationProperties.AutomationId="Stats_PreviewP95Value" Text="0.00ms P95" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Slow" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_PreviewSlowValue" AutomationProperties.AutomationId="Stats_PreviewSlowValue" Grid.Column="1" Text="0 frames (0.0%)" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sampled Crop" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_VisualFpsValue" AutomationProperties.AutomationId="Stats_VisualFpsValue" Text="0.00 fps" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_VisualMotionValue" AutomationProperties.AutomationId="Stats_VisualMotionValue" Text="NoSamples" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="Pipeline_Header" AutomationProperties.AutomationId="Pipeline_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="Pipeline_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Latency" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="Pipeline_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="Pipeline_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Latency" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_PipelineLatencyValue" AutomationProperties.AutomationId="Stats_PipelineLatencyValue" Grid.Column="1" Text="0ms avg" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="Frames_Header" AutomationProperties.AutomationId="Frames_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="Frames_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Frame Counters" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="Frames_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="Frames_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Source" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_SourceDeliveredValue" AutomationProperties.AutomationId="Stats_SourceDeliveredValue" Text="0 delivered" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_SourceDroppedValue" AutomationProperties.AutomationId="Stats_SourceDroppedValue" Text="0 dropped" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DockStatsRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Renderer" Style="{StaticResource DockStatsLabelStyle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <TextBlock x:Name="Stats_RendererRenderedValue" AutomationProperties.AutomationId="Stats_RendererRenderedValue" Text="0 rendered" Style="{StaticResource DockStatsValueStyle}" />
                                        <TextBlock x:Name="Stats_RendererDroppedValue" AutomationProperties.AutomationId="Stats_RendererDroppedValue" Text="0 dropped" Style="{StaticResource DockStatsValueStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="Performance_Header" AutomationProperties.AutomationId="Performance_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="Performance_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="System" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="Performance_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>

                            <StackPanel x:Name="Performance_Content" Spacing="2" Visibility="Collapsed">
                                <Border Style="{StaticResource DockStatsRowAltStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Legacy Score" Style="{StaticResource DockStatsLabelStyle}" />
                                    <TextBlock x:Name="Stats_PerfScoreValue" AutomationProperties.AutomationId="Stats_PerfScoreValue" Grid.Column="1" Text="0.0 / 100" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="Diagnostics_Header" AutomationProperties.AutomationId="Diagnostics_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="Diagnostics_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telemetry Details" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="Diagnostics_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <StackPanel x:Name="Diagnostics_Content" Spacing="2" Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="AvSync_Header" AutomationProperties.AutomationId="AvSync_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="AvSync_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="AV Sync" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="AvSync_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <StackPanel x:Name="AvSync_Content" Spacing="2" Visibility="Collapsed">
                                <Border Padding="8,3" CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Drift" Style="{StaticResource DockStatsLabelStyle}" />
                                        <TextBlock x:Name="Stats_AvSyncDriftValue" AutomationProperties.AutomationId="Stats_AvSyncDriftValue" Grid.Column="1" Text="&#x2014;" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                                <Border Padding="8,3" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Drift Rate" Style="{StaticResource DockStatsLabelStyle}" />
                                        <TextBlock x:Name="Stats_AvSyncDriftRateValue" AutomationProperties.AutomationId="Stats_AvSyncDriftRateValue" Grid.Column="1" Text="&#x2014;" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                                <Border x:Name="Stats_AvSyncEncoderRow" Padding="8,3" CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Encoder" Style="{StaticResource DockStatsLabelStyle}" />
                                        <TextBlock x:Name="Stats_AvSyncEncoderValue" AutomationProperties.AutomationId="Stats_AvSyncEncoderValue" Grid.Column="1" Text="&#x2014;" Style="{StaticResource DockStatsValueStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <Grid x:Name="GPU_Header" AutomationProperties.AutomationId="GPU_Header" Margin="0,0,0,4" Background="Transparent" Tapped="StatsSectionHeader_Tapped" Tag="GPU_Content">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="GPU" Style="{StaticResource DockStatsSectionHeaderStyle}" />
                                <FontIcon x:Name="GPU_Chevron" Grid.Column="1" Glyph="&#xE70D;"
                                          FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                            </Grid>
                            <StackPanel x:Name="GPU_Content" Spacing="2" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        <!-- Row 1: Settings Shelf (own grid row so preview resizes) -->
        <Border x:Name="SettingsOverlayPanel"
                AutomationProperties.AutomationId="SettingsOverlayPanel"
                Grid.Row="1"
                Grid.Column="0"
                Visibility="Collapsed"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,0"
                Padding="12,8"
                CornerRadius="12,12,0,0"
                BorderThickness="0">
            <Border.Background>
                <AcrylicBrush TintColor="#0A0A0A"
                              TintOpacity="0.80"
                              FallbackColor="#141414"/>
            </Border.Background>
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Device -->
                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock Text="Device" FontWeight="SemiBold" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="DeviceComboBox"
                                      AutomationProperties.AutomationId="DeviceComboBox"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      DisplayMemberPath="Name"
                                      PlaceholderText="Select a capture device"/>
                            <Button Grid.Column="1"
                                    x:Name="ApplyDeviceButton"
                                    AutomationProperties.AutomationId="ApplyDeviceButton"
                                    Click="ApplyDeviceButton_Click"
                                    ToolTipService.ToolTip="Apply selected capture device"
                                    IsEnabled="False"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE73E;" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="2"
                                    x:Name="RefreshButton"
                                    AutomationProperties.AutomationId="RefreshButton"
                                    Click="RefreshButton_Click"
                                    ToolTipService.ToolTip="Refresh device list"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            </Button>
                        </Grid>
                        <StackPanel x:Name="DeviceAudioControlPanel"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <ToggleSwitch x:Name="DeviceAudioModeToggle"
                                          AutomationProperties.AutomationId="DeviceAudioModeComboBox"
                                          OffContent="HDMI" OnContent="Analog"
                                          MinWidth="0"
                                          VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="AnalogAudioGainPanel"
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Gain"
                                       Style="{StaticResource SecondaryLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AnalogAudioGainSlider"
                                    AutomationProperties.AutomationId="AnalogAudioGainSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    StepFrequency="1"
                                    TickFrequency="10"
                                    Width="150"
                                    VerticalAlignment="Center">
                                <Slider.Resources>
                                    <Style TargetType="ToolTip">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                    </Style>
                                </Slider.Resources>
                            </Slider>
                            <TextBlock x:Name="AnalogAudioGainValueTextBlock"
                                       Style="{StaticResource SecondaryLabelStyle}"
                                       Text="50%"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="8" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="CustomAudioToggle"
                                  AutomationProperties.AutomationId="CustomAudioToggle"
                                  Content="Alt Audio"
                                  Padding="4,0" MinHeight="0"
                                  VerticalAlignment="Center"/>
                        <ComboBox x:Name="AudioInputComboBox"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  AutomationProperties.AutomationId="AudioInputComboBox"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="Select audio input"
                                  IsEnabled="False"/>
                        <CheckBox x:Name="MicrophoneToggle"
                                  Grid.Row="1"
                                  AutomationProperties.AutomationId="MicrophoneToggle"
                                  Content="Microphone"
                                  Padding="4,0" MinHeight="0"
                                  VerticalAlignment="Center"/>
                        <ComboBox x:Name="MicrophoneComboBox"
                                  Grid.Row="1" Grid.Column="1"
                                  AutomationProperties.AutomationId="MicrophoneComboBox"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="Select microphone"
                                  IsEnabled="False"/>
                        <Slider x:Name="MicVolumeShelfSlider"
                                Grid.Row="1" Grid.Column="2"
                                AutomationProperties.AutomationId="MicVolumeShelfSlider"
                                Minimum="0" Maximum="100" StepFrequency="1"
                                Value="100"
                                Width="80"
                                VerticalAlignment="Center"
                                IsEnabled="False"
                                ToolTipService.ToolTip="Microphone volume"/>
                    </Grid>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1" Background="#0DFFFFFF" Margin="0,2,0,2"/>

                <!-- Encoding -->
                <StackPanel Grid.Row="2" Spacing="6">
                    <TextBlock Text="Encoding" FontWeight="SemiBold" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid x:Name="CaptureSettingsGrid" ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="VideoFormatColumn" Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="PresetColumn" Width="*"/>
                            <ColumnDefinition x:Name="SplitColumn" Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition x:Name="OverflowRow" Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="VideoFormatPanel" Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Video Format"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="VideoFormatComboBox"
                                      AutomationProperties.AutomationId="VideoFormatComboBox"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Resolution"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="ResolutionComboBox"
                                      AutomationProperties.AutomationId="ResolutionComboBox"
                                      HorizontalAlignment="Stretch"
                                      DisplayMemberPath="DisplayText">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                                        <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2">
                            <TextBlock Text="Frame Rate"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="FrameRateComboBox"
                                      AutomationProperties.AutomationId="FrameRateComboBox"
                                      HorizontalAlignment="Stretch"
                                      DisplayMemberPath="DisplayText">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                                        <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="3" Spacing="2">
                            <TextBlock Text="Format"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="FormatComboBox"
                                      AutomationProperties.AutomationId="FormatComboBox"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="4" Spacing="2">
                            <TextBlock Text="Bitrate"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="QualityComboBox"
                                      AutomationProperties.AutomationId="QualityComboBox"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel x:Name="PresetPanel" Grid.Row="0" Grid.Column="5" Spacing="2">
                            <TextBlock Text="NVENC Preset"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="PresetComboBox"
                                      AutomationProperties.AutomationId="PresetComboBox"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel x:Name="CustomBitratePanel"
                                    Grid.Row="0"
                                    Grid.Column="5"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Center">
                            <NumberBox x:Name="CustomBitrateNumberBox"
                                       AutomationProperties.AutomationId="CustomBitrateNumberBox"
                                       Value="50"
                                       Minimum="1"
                                       Maximum="300"
                                       SpinButtonPlacementMode="Compact"
                                       SmallChange="5"
                                       LargeChange="10"
                                       MinWidth="90"/>
                            <TextBlock Text="Mbps"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                        </StackPanel>

                        <StackPanel x:Name="SplitPanel" Grid.Row="0" Grid.Column="6" Spacing="2">
                            <TextBlock Text="Split Encode"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="SplitEncodeComboBox"
                                      AutomationProperties.AutomationId="SplitEncodeComboBox"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel x:Name="DecoderCountPanel" Grid.Row="1" Grid.Column="1" Spacing="2" Visibility="Collapsed">
                            <TextBlock Text="MJPEG Threads"
                                       Style="{StaticResource SecondaryLabelStyle}"/>
                            <ComboBox x:Name="DecoderCountComboBox"
                                      AutomationProperties.AutomationId="DecoderCountComboBox"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="DecoderCountComboBox_SelectionChanged"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Row="3" Height="1" Background="#0DFFFFFF" Margin="0,2,0,2"/>

                <!-- Output -->
                <Grid Grid.Row="4" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputPathTextBox"
                             AutomationProperties.AutomationId="OutputPathTextBox"
                             IsReadOnly="True"
                             VerticalAlignment="Center"
                             FontSize="12"
                             Height="32"/>
                    <Button x:Name="BrowseButton"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="BrowseButton"
                            Click="BrowseButton_Click"
                            Width="32"
                            Height="32"
                            Padding="0"
                            ToolTipService.ToolTip="Choose output folder">
                        <FontIcon Glyph="&#xE838;"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Button>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEDA2;" FontSize="12"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiskSpaceTextBlock"
                                   AutomationProperties.AutomationId="DiskSpaceTextBlock"
                                   Style="{StaticResource SecondaryLabelStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <CheckBox x:Name="ShowAllCaptureOptionsToggle"
                              Grid.Column="3"
                              AutomationProperties.AutomationId="ShowAllCaptureOptionsToggle"
                              Content="Show all"
                              Padding="4,0" MinHeight="0" MinWidth="0"
                              VerticalAlignment="Center"/>
                </Grid>

                <!-- Flashback Settings -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="12"
                            Margin="0,8,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Flashback" FontWeight="SemiBold" FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="FlashbackEnabledToggle"
                                  AutomationProperties.AutomationId="FlashbackEnabledToggle"
                                  OnContent="" OffContent=""
                                  MinWidth="0" MinHeight="0"
                                  Margin="0,-2,0,0"
                                  VerticalAlignment="Center"
                                  Toggled="FlashbackEnabledToggle_Toggled"/>
                    <ComboBox x:Name="FlashbackBufferDurationCombo"
                              AutomationProperties.AutomationId="FlashbackBufferDurationCombo"
                              Width="160"
                              VerticalAlignment="Center"
                              SelectionChanged="FlashbackBufferDurationCombo_SelectionChanged">
                        <ComboBoxItem Content="1 minute" Tag="1"/>
                        <ComboBoxItem Content="2 minutes" Tag="2"/>
                        <ComboBoxItem Content="5 minutes" Tag="5" IsSelected="True"/>
                        <ComboBoxItem Content="10 minutes" Tag="10"/>
                        <ComboBoxItem Content="15 minutes" Tag="15"/>
                        <ComboBoxItem Content="30 minutes" Tag="30"/>
                    </ComboBox>
                    <Button x:Name="FlashbackApplyButton"
                            AutomationProperties.AutomationId="FlashbackApplyButton"
                            Content="Apply"
                            Height="28" Padding="12,0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Restart flashback with current settings (clears buffer)"
                            Click="FlashbackApplyButton_Click"/>
                    <TextBlock x:Name="FlashbackDiskEstimateText"
                               AutomationProperties.AutomationId="FlashbackDiskEstimateText"
                               FontSize="11" Foreground="#80FFFFFF"
                               VerticalAlignment="Center"
                               Text="~1.3 GB"/>
                    <TextBlock Text="GPU Decode" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <ToggleSwitch x:Name="FlashbackGpuDecodeToggle"
                                  AutomationProperties.AutomationId="FlashbackGpuDecodeToggle"
                                  OnContent="" OffContent=""
                                  MinWidth="0" MinHeight="0"
                                  Margin="0,-2,0,0"
                                  VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Flashback Timeline (collapsed by default) -->
        <Border x:Name="FlashbackTimelinePanel" Grid.Row="2" Grid.Column="0"
                AutomationProperties.AutomationId="FlashbackTimelinePanel"
                Visibility="Collapsed"
                Margin="16,0,16,8"
                Padding="12,8,12,8"
                CornerRadius="8"
                Background="#E6202020"
                BorderBrush="#20FFFFFF" BorderThickness="1">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Status -->
                <Grid Grid.Row="0">
                    <TextBlock x:Name="FlashbackBufferDurationText"
                               AutomationProperties.AutomationId="FlashbackBufferDurationText"
                               Foreground="#80FFFFFF" FontSize="11" FontFamily="Consolas"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Row 1: Scrub Track -->
                <Canvas Grid.Row="1" Height="32"
                        SizeChanged="FlashbackTrack_SizeChanged">
                    <!-- Dark track background -->
                    <Border x:Name="FlashbackTrackBackground"
                            CornerRadius="4" Background="#FF141414"
                            Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Selection region between in/out points -->
                    <Border x:Name="FlashbackSelectionRegion"
                            Background="#3000CED1" Visibility="Collapsed"
                            Canvas.Top="0"/>
                    <!-- Playhead line -->
                    <Border x:Name="FlashbackPlayhead"
                            Width="2" Background="White"
                            Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Playhead handle (circle at top) -->
                    <Border x:Name="FlashbackPlayheadHandle"
                            Width="10" Height="10" CornerRadius="5"
                            Background="White" BorderBrush="#40000000" BorderThickness="1"
                            Canvas.Left="0" Canvas.Top="-4"/>
                    <!-- Floating time label above playhead -->
                    <Border x:Name="FlashbackPlayheadTimeBorder"
                            Background="#CC141414" CornerRadius="3" Padding="4,1"
                            Canvas.Top="-20">
                        <TextBlock x:Name="FlashbackPlayheadTimeText"
                                   AutomationProperties.AutomationId="FlashbackPlayheadTimeText"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="White"/>
                    </Border>
                    <!-- Live edge indicator (hidden — playhead already shows position) -->
                    <Border x:Name="FlashbackLiveEdge"
                            Width="2" Background="#00CED1"
                            CornerRadius="1"
                            Canvas.Top="0"
                            Visibility="Collapsed"/>
                    <!-- In point marker -->
                    <Border x:Name="FlashbackInPointMarker"
                            Width="2" Background="#FFD700"
                            Visibility="Collapsed" CornerRadius="1"
                            Canvas.Top="0"/>
                    <!-- Out point marker -->
                    <Border x:Name="FlashbackOutPointMarker"
                            Width="2" Background="#FFD700"
                            Visibility="Collapsed" CornerRadius="1"
                            Canvas.Top="0"/>
                    <!-- Hit-test overlay for pointer events -->
                    <Border x:Name="FlashbackScrubArea"
                            AutomationProperties.AutomationId="FlashbackScrubArea"
                            Background="Transparent"
                            Canvas.Left="0" Canvas.Top="0"
                            PointerPressed="FlashbackScrubArea_PointerPressed"
                            PointerMoved="FlashbackScrubArea_PointerMoved"
                            PointerReleased="FlashbackScrubArea_PointerReleased"
                            PointerCanceled="FlashbackScrubArea_PointerCanceled"
                            PointerCaptureLost="FlashbackScrubArea_PointerCaptureLost"/>
                </Canvas>

                <!-- Row 2: Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                    <Button x:Name="FlashbackInButton" AutomationProperties.AutomationId="FlashbackInButton" Content="In" Width="40" Height="28"
                            FontSize="11" Padding="0" CornerRadius="6"
                            Click="FlashbackInButton_Click"
                            ToolTipService.ToolTip="Set in point (I)"/>
                    <Button x:Name="FlashbackOutButton" AutomationProperties.AutomationId="FlashbackOutButton" Content="Out" Width="40" Height="28"
                            FontSize="11" Padding="0" CornerRadius="6"
                            Click="FlashbackOutButton_Click"
                            ToolTipService.ToolTip="Set out point (O)"/>
                    <Button x:Name="FlashbackClearButton" AutomationProperties.AutomationId="FlashbackClearButton" Content="Clear" Height="28"
                            FontSize="11" Padding="8,0" CornerRadius="6"
                            Click="FlashbackClearButton_Click"
                            ToolTipService.ToolTip="Clear in/out points"/>
                    <Border Width="1" Height="16" Background="#30FFFFFF" Margin="4,0"/>
                    <Button x:Name="FlashbackPlayPauseButton" AutomationProperties.AutomationId="FlashbackPlayPauseButton" Width="36" Height="28"
                            Padding="0" CornerRadius="6"
                            Click="FlashbackPlayPauseButton_Click"
                            ToolTipService.ToolTip="Play/Pause (Space)">
                        <FontIcon x:Name="FlashbackPlayPauseIcon" Glyph="&#xE768;" FontSize="14"/>
                    </Button>
                    <Button x:Name="FlashbackGoLiveButton" AutomationProperties.AutomationId="FlashbackGoLiveButton" Content="Go Live" Height="28"
                            FontSize="11" Padding="8,0" CornerRadius="6"
                            Foreground="#00CED1"
                            Click="FlashbackGoLiveButton_Click"
                            ToolTipService.ToolTip="Return to live (L)"/>
                    <Border Width="1" Height="16" Background="#30FFFFFF" Margin="4,0"/>
                    <Button x:Name="FlashbackExportButton" AutomationProperties.AutomationId="FlashbackExportButton" Height="28"
                            FontSize="11" Padding="8,0" CornerRadius="6"
                            Click="FlashbackExportButton_Click"
                            ToolTipService.ToolTip="Export selection">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE78C;" FontSize="12"/>
                            <TextBlock Text="Export" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="FlashbackSaveLast5mButton" AutomationProperties.AutomationId="FlashbackSaveLast5mButton" Content="Save Last 5m" Height="28"
                            FontSize="11" Padding="8,0" CornerRadius="6"
                            Click="FlashbackSaveLast5mButton_Click"
                            ToolTipService.ToolTip="Save last 5 minutes"/>
                </StackPanel>

                <!-- Row 3: Export Progress -->
                <ProgressBar x:Name="FlashbackExportProgressBar" AutomationProperties.AutomationId="FlashbackExportProgressBar" Grid.Row="3"
                             Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed"
                             Height="4" CornerRadius="2"
                             Margin="0,2,0,0"/>
            </Grid>
        </Border>

        <!-- Row 3: Two-Tier Control Bar -->
        <Border x:Name="ControlBarShadowHost" Grid.Row="3" Grid.Column="0"
                Background="Transparent"
                IsHitTestVisible="False"/>
        <Border x:Name="ControlBarBorder" Grid.Row="3" Grid.Column="0"
                AutomationProperties.AutomationId="ControlBarBorder"
                Margin="16,8,16,16"
                BorderBrush="#10FFFFFF" BorderThickness="1"
                CornerRadius="12" Padding="16,12">
            <Border.Background>
                <AcrylicBrush TintColor="#141414"
                              TintOpacity="0.85"
                              FallbackColor="#1C1C1C"/>
            </Border.Background>
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Stats + live signal + audio meter -->
                <StackPanel x:Name="StatsRow" Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <StackPanel.ChildrenTransitions>
                        <RepositionThemeTransition/>
                    </StackPanel.ChildrenTransitions>
                    <StackPanel x:Name="RecordingStatsPanel" AutomationProperties.AutomationId="RecordingStatsPanel" Orientation="Horizontal" Spacing="16"
                                VerticalAlignment="Center" MinWidth="220">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Size:" Style="{StaticResource SecondaryLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingSizeTextBlock"
                                       AutomationProperties.AutomationId="RecordingSizeTextBlock"
                                       FontFamily="Consolas" MinWidth="65"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="|" Opacity="0.3" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Bitrate:" Style="{StaticResource SecondaryLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingBitrateTextBlock"
                                       AutomationProperties.AutomationId="RecordingBitrateTextBlock"
                                       FontFamily="Consolas" MinWidth="75"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="LiveSignalInfoPanel" AutomationProperties.AutomationId="LiveSignalInfoPanel" Orientation="Horizontal" Spacing="8"
                                Visibility="Collapsed" Opacity="0">
                        <StackPanel.RenderTransform>
                            <ScaleTransform x:Name="LiveSignalInfoScale" ScaleX="0.92" ScaleY="0.92"/>
                        </StackPanel.RenderTransform>
                        <StackPanel Orientation="Horizontal" Spacing="4" ToolTipService.ToolTip="Live resolution">
                            <FontIcon Glyph="&#xE7F4;" FontSize="12"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="LiveResolutionTextBlock"
                                       AutomationProperties.AutomationId="LiveResolutionTextBlock"
                                       Text="&#x2014;"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" ToolTipService.ToolTip="Live frame rate">
                            <FontIcon Glyph="&#xE916;" FontSize="12"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="LiveFrameRateTextBlock"
                                       AutomationProperties.AutomationId="LiveFrameRateTextBlock"
                                       Text="&#x2014;"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" ToolTipService.ToolTip="Live pixel format">
                            <FontIcon Glyph="&#xE950;" FontSize="12"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="LivePixelFormatTextBlock"
                                       AutomationProperties.AutomationId="LivePixelFormatTextBlock"
                                       Text="&#x2014;"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid VerticalAlignment="Center" RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="DeviceAudioRow" Grid.Row="0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="DeviceAudioRowTranslate" Y="7"/>
                            </Grid.RenderTransform>
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="80" MaxWidth="200"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                        <Border x:Name="AudioMeterTrack"
                                AutomationProperties.AutomationId="AudioMeterTrack"
                                Grid.Column="0"
                                MinWidth="80" MaxWidth="200" Height="8"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AudioMeterTrackBrush}"
                                BorderBrush="{ThemeResource AudioMeterBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                VerticalAlignment="Center">
                            <Grid x:Name="AudioMeterContent">
                                <Border x:Name="AudioMeterRawFill"
                                        HorizontalAlignment="Stretch">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#FF606060" Offset="0"/>
                                            <GradientStop Color="#FF787878" Offset="0.55"/>
                                            <GradientStop Color="#FF8C8C8C" Offset="0.75"/>
                                            <GradientStop Color="#FF6E6E6E" Offset="0.90"/>
                                            <GradientStop Color="#FF5A5A5A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Clip>
                                        <RectangleGeometry x:Name="AudioMeterRawClip" Rect="0,0,0,8"/>
                                    </Border.Clip>
                                </Border>
                                <Border x:Name="AudioMeterFill"
                                        HorizontalAlignment="Stretch">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#00CED1" Offset="0"/>
                                            <GradientStop Color="#00E5B0" Offset="0.55"/>
                                            <GradientStop Color="#FFD700" Offset="0.75"/>
                                            <GradientStop Color="#FF6B3D" Offset="0.90"/>
                                            <GradientStop Color="#FF1744" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Clip>
                                        <RectangleGeometry x:Name="AudioMeterColorClip" Rect="0,0,0,8"/>
                                    </Border.Clip>
                                </Border>

                                <Border x:Name="AudioPeakHoldIndicator"
                                        Width="2"
                                        Height="8"
                                        Background="#FFFFFF"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Opacity="0.9"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="AudioPeakHoldTranslate" X="0"/>
                                    </Border.RenderTransform>
                                </Border>

                                <Border x:Name="AudioRangeMinMarker"
                                        Width="1"
                                        Height="8"
                                        Background="#50FFFFFF"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Opacity="0.5"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="AudioRangeMinTranslate" X="0"/>
                                    </Border.RenderTransform>
                                </Border>

                                <Border x:Name="AudioRangeMaxMarker"
                                        Width="1"
                                        Height="8"
                                        Background="#80FFFFFF"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Opacity="0.7"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="AudioRangeMaxTranslate" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <Slider x:Name="PreviewVolumeSlider"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="PreviewVolumeSlider"
                                Minimum="0" Maximum="100" StepFrequency="1"
                                Value="0"
                                Width="70" MinHeight="0"
                                Padding="0" Margin="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Preview volume">
                            <Slider.Resources>
                                <x:Double x:Key="SliderHorizontalHeight">10</x:Double>
                                <x:Double x:Key="SliderTrackThemeHeight">2</x:Double>
                                <x:Double x:Key="SliderHorizontalThumbWidth">10</x:Double>
                                <x:Double x:Key="SliderHorizontalThumbHeight">10</x:Double>
                                <CornerRadius x:Key="SliderThumbCornerRadius">5</CornerRadius>
                                <Thickness x:Key="SliderTopHeaderMargin">0</Thickness>
                                <x:Double x:Key="SliderPreContentMargin">0</x:Double>
                                <x:Double x:Key="SliderPostContentMargin">0</x:Double>
                                <Style TargetType="ToolTip">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                </Style>
                            </Slider.Resources>
                        </Slider>
                        <TextBlock x:Name="PreviewVolumeLabel"
                                   AutomationProperties.AutomationId="PreviewVolumeLabel"
                                   Grid.Column="2"
                                   FontSize="10"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Text="100%"/>
                            </Grid>
                        </Grid>

                        <Grid x:Name="MicMeterRow" Grid.Row="1"
                              Height="14" Opacity="0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="MicMeterRowTranslate" Y="14"/>
                            </Grid.RenderTransform>
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="80" MaxWidth="200"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="MicMeterTrack"
                                        AutomationProperties.AutomationId="MicMeterTrack"
                                        Grid.Column="0"
                                        MinWidth="80" MaxWidth="200" Height="8"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource AudioMeterTrackBrush}"
                                        BorderBrush="{ThemeResource AudioMeterBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Grid x:Name="MicMeterContent">
                                        <Border x:Name="MicMeterFill"
                                                HorizontalAlignment="Stretch">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Color="#00CED1" Offset="0.0"/>
                                                    <GradientStop Color="#00E5B0" Offset="0.3"/>
                                                    <GradientStop Color="#FFD700" Offset="0.6"/>
                                                    <GradientStop Color="#FF6B3D" Offset="0.8"/>
                                                    <GradientStop Color="#FF1744" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Clip>
                                                <RectangleGeometry x:Name="MicMeterClip" Rect="0,0,0,8"/>
                                            </Border.Clip>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Slider x:Name="MicVolumeSlider"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="MicVolumeSlider"
                                        Minimum="0" Maximum="100" StepFrequency="1"
                                        Value="100"
                                        Width="70" MinHeight="0"
                                        Padding="0" Margin="0"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Microphone volume">
                                    <Slider.Resources>
                                        <x:Double x:Key="SliderHorizontalHeight">10</x:Double>
                                        <x:Double x:Key="SliderTrackThemeHeight">2</x:Double>
                                        <x:Double x:Key="SliderHorizontalThumbWidth">10</x:Double>
                                        <x:Double x:Key="SliderHorizontalThumbHeight">10</x:Double>
                                        <CornerRadius x:Key="SliderThumbCornerRadius">5</CornerRadius>
                                        <Thickness x:Key="SliderTopHeaderMargin">0</Thickness>
                                        <x:Double x:Key="SliderPreContentMargin">0</x:Double>
                                        <x:Double x:Key="SliderPostContentMargin">0</x:Double>
                                        <Style TargetType="ToolTip">
                                            <Setter Property="Opacity" Value="0"/>
                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                        </Style>
                                    </Slider.Resources>
                                </Slider>
                                <TextBlock x:Name="MicVolumeLabel"
                                           AutomationProperties.AutomationId="MicVolumeLabel"
                                           Grid.Column="2"
                                           FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Text="100%"/>
                            </Grid>
                        </Grid>
                    </Grid>
                    <TextBlock x:Name="AudioClipText"
                               AutomationProperties.AutomationId="AudioClipText"
                               Text="CLIP"
                               Foreground="{ThemeResource ClipAlertBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Visibility="Collapsed"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                           Grid.Row="1"
                           AutomationProperties.AutomationId="StatusTextBlock"
                           Text="Ready"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           FontSize="12"
                           Opacity="0.78"
                           VerticalAlignment="Center"/>

                <!-- Row 2: Controls -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <!-- Floating Cinema: accent-driven, borderless, ghost buttons -->
                        <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>

                        <!-- Button: ghost style with dim-to-bright -->
                        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#12FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#08FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent"/>
                        <SolidColorBrush x:Key="ButtonForeground" Color="#707070"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#A0A0A0"/>
                        <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#3A3A3A"/>

                        <!-- ToggleButton unchecked: same ghost style -->
                        <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#12FFFFFF"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#08FFFFFF"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundDisabled" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushDisabled" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonForeground" Color="#707070"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#A0A0A0"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="#3A3A3A"/>

                        <!-- ToggleButton checked: teal accent glow -->
                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#1800CED1"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#2400CED1"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#1000CED1"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedDisabled" Color="#0800CED1"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedDisabled" Color="Transparent"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#00CED1"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#3FE8E8"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#00A5A8"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedDisabled" Color="#1A6B6D"/>
                    </StackPanel.Resources>
                    <Button x:Name="SettingsToggleButton"
                            AutomationProperties.AutomationId="SettingsToggleButton"
                            Click="SettingsToggleButton_Click"
                            VerticalAlignment="Center"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="8"
                            ToolTipService.ToolTip="Device and output settings (Ctrl+D)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="D" Modifiers="Control"/>
                        </Button.KeyboardAccelerators>
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                    <Button x:Name="OpenRecordingsButton"
                            AutomationProperties.AutomationId="OpenRecordingsButton"
                            Click="OpenRecordingsButton_Click"
                            VerticalAlignment="Center"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="8"
                            ToolTipService.ToolTip="Open recordings folder (Ctrl+E)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="E" Modifiers="Control"/>
                        </Button.KeyboardAccelerators>
                        <Grid>
                            <FontIcon Glyph="&#xE8B7;" FontSize="15"/>
                            <FontIcon Glyph="&#xE768;" FontSize="6" Margin="1,2,0,0"/>
                        </Grid>
                    </Button>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <Button x:Name="ScreenshotButton"
                            AutomationProperties.AutomationId="ScreenshotButton"
                            Click="ScreenshotButton_Click"
                            VerticalAlignment="Center"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="8"
                            ToolTipService.ToolTip="Capture screenshot (Ctrl+Shift+S)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="S" Modifiers="Control,Shift"/>
                        </Button.KeyboardAccelerators>
                        <FontIcon Glyph="&#xE722;" FontSize="14"/>
                    </Button>
                    <Button x:Name="RecordButton"
                            AutomationProperties.AutomationId="RecordButton"
                            Click="RecordButton_Click"
                            Height="36"
                            Width="36"
                            Padding="0"
                            Background="{ThemeResource RecordButtonBrush}"
                            BorderBrush="Transparent"
                            CornerRadius="18"
                            ToolTipService.ToolTip="Start/stop recording (Ctrl+R)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="R" Modifiers="Control"/>
                        </Button.KeyboardAccelerators>
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#E81123"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF4D5E"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC0E1B"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#CC0E1B"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#E0E0E0"/>
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="White"/>
                        </Button.Resources>
                        <Grid>
                            <!-- Idle state: white dot -->
                            <Ellipse x:Name="RecordButtonNormalContent"
                                     Width="12" Height="12" Fill="White"/>
                            <!-- Starting/stopping state: spinner -->
                            <ProgressRing x:Name="RecordButtonStartingContent"
                                          Width="16" Height="16"
                                          IsActive="False"
                                          Foreground="White"
                                          Visibility="Collapsed"/>
                            <!-- Recording state: stop square + time -->
                            <StackPanel x:Name="RecordButtonRecordingContent"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center">
                                <Border Width="12" Height="12"
                                        Background="#1A1A1A"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"/>
                                <TextBlock x:Name="RecordingTimeTextBlock"
                                           AutomationProperties.AutomationId="RecordingTimeTextBlock"
                                           Text="00:00:00"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button x:Name="PreviewButton"
                            AutomationProperties.AutomationId="PreviewButton"
                            Click="PreviewButton_Click"
                            VerticalAlignment="Center"
                            Height="36"
                            Padding="10,0"
                            CornerRadius="8"
                            ToolTipService.ToolTip="Start Preview (Ctrl+P)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="P" Modifiers="Control"/>
                        </Button.KeyboardAccelerators>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="PreviewButtonIcon" Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock x:Name="PreviewButtonLabel" Text="Preview"
                                       FontSize="12" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <ToggleButton x:Name="HdrToggle"
                                  AutomationProperties.AutomationId="HdrToggle"
                                  Height="32"
                                  Padding="8,0"
                                  ToolTipService.ToolTip="HDR recording">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE706;" FontSize="14"/>
                            <TextBlock x:Name="HdrToggleLabel"
                                       Text="HDR"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="AudioRecordToggle"
                                  AutomationProperties.AutomationId="AudioRecordToggle"
                                  IsChecked="True"
                                  Height="32"
                                  Padding="8,0"
                                  ToolTipService.ToolTip="Record audio">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE720;" FontSize="14"/>
                            <TextBlock x:Name="AudioRecordToggleLabel"
                                       Text="Audio"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <ToggleButton x:Name="TrueHdrPreviewToggle"
                                  AutomationProperties.AutomationId="TrueHdrPreviewToggle"
                                  Height="32" Padding="8,0"
                                  ToolTipService.ToolTip="True HDR preview">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7B3;" FontSize="14"/>
                            <TextBlock x:Name="HdrPreviewToggleLabel" Text="HDR Preview"
                                       FontSize="12" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="AudioPreviewToggle"
                                  AutomationProperties.AutomationId="AudioPreviewToggle"
                                  IsChecked="True"
                                  Height="32" Padding="8,0"
                                  ToolTipService.ToolTip="Preview audio">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE767;" FontSize="14"/>
                            <TextBlock x:Name="AudioPreviewToggleLabel" Text="Monitor"
                                       FontSize="12" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <ToggleButton x:Name="StatsToggle"
                                  AutomationProperties.AutomationId="StatsToggle"
                                  Height="32"
                                  Padding="8,0"
                                  ToolTipService.ToolTip="Frame statistics">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14"/>
                            <TextBlock x:Name="StatsToggleLabel"
                                       Text="Stats"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="FrameTimeOverlayToggle"
                                  AutomationProperties.AutomationId="FrameTimeOverlayToggle"
                                  Height="32"
                                  Padding="8,0"
                                  ToolTipService.ToolTip="Frame-time overlay">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE9D2;" FontSize="14"/>
                            <TextBlock x:Name="FrameTimeOverlayToggleLabel"
                                       Text="Frame Time"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <ToggleButton x:Name="FlashbackToggle"
                                  AutomationProperties.AutomationId="FlashbackToggle"
                                  Height="32"
                                  Padding="8,0"
                                  ToolTipService.ToolTip="Flashback timeline"
                                  Checked="FlashbackToggle_Checked"
                                  Unchecked="FlashbackToggle_Unchecked">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                            <TextBlock x:Name="FlashbackToggleLabel"
                                       Text="Flashback"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ToggleButton>
                    <Border Width="1" Height="20" Background="{ThemeResource ToolbarSeparatorBrush}" Opacity="0.4" Margin="4,0"/>
                    <Button x:Name="FullScreenButton"
                            AutomationProperties.AutomationId="FullScreenButton"
                            Click="FullScreenButton_Click"
                            VerticalAlignment="Center"
                            Width="36" Height="36"
                            Padding="0" CornerRadius="8"
                            ToolTipService.ToolTip="Full screen (F11)">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F11"/>
                        </Button.KeyboardAccelerators>
                        <FontIcon x:Name="FullScreenButtonIcon" Glyph="&#xE740;" FontSize="14"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Fullscreen: VLC-style slide-up controls overlay -->
        <StackPanel x:Name="FullScreenControlsOverlay"
                    AutomationProperties.AutomationId="FullScreenControlsOverlay"
                    Grid.RowSpan="4" Grid.ColumnSpan="2"
                    Visibility="Collapsed"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    Canvas.ZIndex="10"/>

        <!-- Startup Splash Overlay -->
        <Grid x:Name="SplashOverlay" Grid.RowSpan="4" Grid.ColumnSpan="2"
              AutomationProperties.AutomationId="SplashOverlay"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="SplashScale" ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            <StackPanel x:Name="SplashContent"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="6"
                        Opacity="0">
                <TextBlock Text="Sussudio"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           CharacterSpacing="40">
                    <TextBlock.Shadow>
                        <ThemeShadow/>
                    </TextBlock.Shadow>
                </TextBlock>
                <Grid x:Name="SplashLoadingArea" Height="20" HorizontalAlignment="Center">
                    <Grid.Clip>
                        <RectangleGeometry Rect="-2000,0,4000,20"/>
                    </Grid.Clip>
                    <TextBlock x:Name="SplashLoadingTextA"
                               Text=""
                               FontSize="13"
                               FontWeight="Normal"
                               FontStyle="Italic"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               CharacterSpacing="60"
                               Opacity="0.6">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="SplashLoadingTransformA" Y="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="SplashLoadingTextB"
                               Text=""
                               FontSize="13"
                               FontWeight="Normal"
                               FontStyle="Italic"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               CharacterSpacing="60"
                               Opacity="0">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="SplashLoadingTransformB" Y="18"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
