<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ElgatoCapture.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElgatoCapture"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Elgato Capture">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Device Selection Row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Device:"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       FontWeight="SemiBold"/>

            <ComboBox Grid.Column="1"
                      x:Name="DeviceComboBox"
                      HorizontalAlignment="Stretch"
                      DisplayMemberPath="Name"
                      PlaceholderText="Select a capture device"/>

            <Button Grid.Column="2"
                    x:Name="RefreshButton"
                    Margin="8,0,0,0"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh device list">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- Video Preview Area -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- Preview placeholder - actual MediaCapture preview handled in code -->
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <!-- Recording Indicator -->
                <Border x:Name="RecordingIndicator"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="8,4"
                        CornerRadius="4"
                        Background="#E0FF0000">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="RecIndicatorDot" Width="10" Height="10" Fill="White"/>
                        <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- No Device Placeholder -->
                <StackPanel x:Name="NoDevicePlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE714;" FontSize="64" Opacity="0.3"/>
                    <TextBlock Text="No preview available"
                               Opacity="0.5"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a device and click Start Preview"
                               Opacity="0.3"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings Row -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Resolution -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Resolution" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="ResolutionComboBox"
                          MinWidth="120"/>
            </StackPanel>

            <!-- Frame Rate -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Frame Rate" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="FrameRateComboBox"
                          MinWidth="90"/>
            </StackPanel>

            <!-- Recording Format (codec) -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Format" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="FormatComboBox"
                          MinWidth="160"/>
            </StackPanel>

            <!-- Quality -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Quality" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="QualityComboBox"
                          MinWidth="100"/>
            </StackPanel>

            <!-- Custom Bitrate (visible only when Quality is Custom) -->
            <StackPanel x:Name="CustomBitratePanel" Grid.Column="4" Visibility="Collapsed">
                <TextBlock Text="Bitrate" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <NumberBox x:Name="CustomBitrateNumberBox"
                               Value="50"
                               Minimum="1"
                               Maximum="300"
                               SpinButtonPlacementMode="Compact"
                               SmallChange="5"
                               LargeChange="10"
                               MinWidth="90"/>
                    <TextBlock Text="Mbps" VerticalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>

            <!-- Spacer -->
            <Border Grid.Column="5"/>

            <!-- HDR Toggle -->
            <StackPanel Grid.Column="6" VerticalAlignment="Center">
                <TextBlock Text="HDR" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ToggleSwitch x:Name="HdrToggle"
                              OnContent="On" OffContent="Off"
                              MinWidth="0"/>
            </StackPanel>

            <!-- Audio Preview Toggle -->
            <StackPanel Grid.Column="7" VerticalAlignment="Center">
                <TextBlock Text="Audio" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ToggleButton x:Name="AudioPreviewToggle"
                              IsChecked="True"
                              Width="40"
                              Height="32"
                              ToolTipService.ToolTip="Toggle audio preview">
                    <FontIcon Glyph="&#xE767;" FontSize="14"/>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Bottom Controls Row -->
        <Grid Grid.Row="3" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Output Path and Status -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="8">
                <!-- Output Path Row -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Output:"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Opacity="0.7"/>
                    <TextBox Grid.Column="1"
                             x:Name="OutputPathTextBox"
                             IsReadOnly="True"
                             VerticalAlignment="Center"
                             FontSize="12"/>
                    <Button Grid.Column="2"
                            x:Name="BrowseButton"
                            Content="Browse..."
                            Click="BrowseButton_Click"
                            Padding="12,4"/>
                </Grid>

                <!-- Status Row -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Status:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Ready"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Disk Space -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEDA2;" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiskSpaceTextBlock"
                                   FontSize="12"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Recording Controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <!-- Preview Button -->
                <Button x:Name="PreviewButton"
                        Content="Start Preview"
                        Click="PreviewButton_Click"
                        VerticalAlignment="Center"
                        Height="40"
                        Padding="16,0"/>

                <!-- Record Button - transforms to show timer when recording -->
                <Button x:Name="RecordButton"
                        Click="RecordButton_Click"
                        Height="44"
                        MinWidth="140"
                        Padding="16,0"
                        Background="#E81123"
                        BorderBrush="#C50F1F"
                        CornerRadius="4">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver">#F1707A</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed">#C50F1F</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForeground">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPressed">White</SolidColorBrush>
                    </Button.Resources>

                    <Grid>
                        <!-- Normal state: RECORD -->
                        <StackPanel x:Name="RecordButtonNormalContent"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="White" VerticalAlignment="Center"/>
                            <TextBlock Text="RECORD"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Recording state: Timer + Stop -->
                        <StackPanel x:Name="RecordButtonRecordingContent"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="RecordingTimeTextBlock"
                                       Text="00:00:00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Border Width="14" Height="14"
                                    Background="White"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
