<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ElgatoCapture.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElgatoCapture"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Elgato Capture">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Device Selection Row -->
        <Grid Grid.Row="0" ColumnSpacing="10" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Device"
                       FontSize="12"
                       Opacity="0.7"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"/>

            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="Custom Audio Input"
                       FontSize="12"
                       Opacity="0.7"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"/>

            <TextBlock x:Name="AudioInputLabel"
                       Grid.Row="0" Grid.Column="3"
                       Text="Audio Input"
                       FontSize="12"
                       Opacity="0.7"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"
                       Visibility="Collapsed"/>

            <ComboBox Grid.Row="1" Grid.Column="0"
                      x:Name="DeviceComboBox"
                      AutomationProperties.AutomationId="DeviceComboBox"
                      Width="520"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      PlaceholderText="Select a capture device"/>

            <Button Grid.Row="1" Grid.Column="1"
                    x:Name="RefreshButton"
                    AutomationProperties.AutomationId="RefreshButton"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh device list"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>

            <ToggleSwitch Grid.Row="1" Grid.Column="2"
                          x:Name="CustomAudioToggle"
                          AutomationProperties.AutomationId="CustomAudioToggle"
                          OnContent="On" OffContent="Off"
                          MinWidth="0"
                          VerticalAlignment="Center"
                          Margin="0,2,0,0"/>

            <ComboBox Grid.Row="1" Grid.Column="3"
                      x:Name="AudioInputComboBox"
                      AutomationProperties.AutomationId="AudioInputComboBox"
                      Width="320"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      PlaceholderText="Select audio input"
                      Visibility="Collapsed"/>
        </Grid>

        <!-- Video Preview Area -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- Primary GPU preview path -->
                <MediaPlayerElement x:Name="PreviewPlayerElement"
                                    AutomationProperties.AutomationId="PreviewPlayerElement"
                                    AreTransportControlsEnabled="False"
                                    AutoPlay="False"
                                    IsHitTestVisible="False"
                                    Stretch="Uniform"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />

                <!-- Fallback CPU preview path -->
                <Image x:Name="PreviewImage"
                       AutomationProperties.AutomationId="PreviewImage"
                       Stretch="Uniform"
                       Visibility="Collapsed"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <!-- Recording Indicator -->
                <Border x:Name="RecordingIndicator"
                        AutomationProperties.AutomationId="RecordingIndicator"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="8,4"
                        CornerRadius="4"
                        Background="#E0FF0000">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="RecIndicatorDot" Width="10" Height="10" Fill="White"/>
                        <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- No Device Placeholder -->
                <StackPanel x:Name="NoDevicePlaceholder"
                            AutomationProperties.AutomationId="NoDevicePlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE714;" FontSize="64" Opacity="0.3"/>
                    <TextBlock Text="No preview available"
                               Opacity="0.5"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a device and click Start Preview"
                               Opacity="0.3"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings Row -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Resolution -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Resolution" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="ResolutionComboBox"
                          AutomationProperties.AutomationId="ResolutionComboBox"
                          MinWidth="120"
                          DisplayMemberPath="DisplayText">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                            <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </StackPanel>

            <!-- Frame Rate -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Frame Rate" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <TextBlock x:Name="HdrFpsHintTextBlock"
                           AutomationProperties.AutomationId="HdrFpsHintTextBlock"
                           FontSize="11"
                           Foreground="#F5C542"
                           Opacity="0.9"
                           Margin="0,0,0,4"
                           TextWrapping="Wrap"
                           MaxWidth="200"
                           Visibility="Collapsed"/>
                <ComboBox x:Name="FrameRateComboBox"
                          AutomationProperties.AutomationId="FrameRateComboBox"
                          MinWidth="90"
                          DisplayMemberPath="DisplayText">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                            <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </StackPanel>

            <!-- Recording Format (codec) -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Format" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="FormatComboBox"
                          AutomationProperties.AutomationId="FormatComboBox"
                          MinWidth="160"/>
            </StackPanel>

            <!-- Quality -->
            <StackPanel Grid.Column="3">
                <TextBlock Text="Quality" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <ComboBox x:Name="QualityComboBox"
                          AutomationProperties.AutomationId="QualityComboBox"
                          MinWidth="100"/>
            </StackPanel>

            <!-- Custom Bitrate (visible only when Quality is Custom) -->
            <StackPanel x:Name="CustomBitratePanel" Grid.Column="4" Visibility="Collapsed">
                <TextBlock Text="Bitrate" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <NumberBox x:Name="CustomBitrateNumberBox"
                               AutomationProperties.AutomationId="CustomBitrateNumberBox"
                               Value="50"
                               Minimum="1"
                               Maximum="300"
                               SpinButtonPlacementMode="Compact"
                               SmallChange="5"
                               LargeChange="10"
                               MinWidth="90"/>
                    <TextBlock Text="Mbps" VerticalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>

            <!-- Spacer -->
            <Border Grid.Column="5"/>

            <!-- HDR + Audio Controls -->
            <StackPanel Grid.Column="6"
                        Grid.ColumnSpan="4"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HDR" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                    <ToggleSwitch x:Name="HdrToggle"
                                  AutomationProperties.AutomationId="HdrToggle"
                                  OnContent="" OffContent=""
                                  Width="44"
                                  Height="32"
                                  MinWidth="0"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Grid x:Name="AudioMeterTrack" Width="200" Height="8">
                            <Border Background="#1E1E1E"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Grid x:Name="AudioMeterFillHost">
                                    <Rectangle x:Name="AudioMeterFill"
                                               Height="6"
                                               RadiusX="1"
                                               RadiusY="1"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#32CD32" Offset="0"/>
                                                <GradientStop Color="#32CD32" Offset="0.6667"/>
                                                <GradientStop Color="#DAA520" Offset="0.6667"/>
                                                <GradientStop Color="#DAA520" Offset="0.85"/>
                                                <GradientStop Color="#FF4500" Offset="0.85"/>
                                                <GradientStop Color="#FF4500" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle x:Name="AudioMeterMask"
                                               Height="6"
                                               RadiusX="1"
                                               RadiusY="1"
                                               Fill="#1E1E1E"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="AudioClipText"
                                   AutomationProperties.AutomationId="AudioClipText"
                                   Text="CLIP"
                                   Foreground="#D13438"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleButton x:Name="AudioRecordToggle"
                                      AutomationProperties.AutomationId="AudioRecordToggle"
                                      IsChecked="True"
                                      Width="44"
                                      Height="32"
                                      ToolTipService.ToolTip="Record audio">
                            <FontIcon Glyph="&#xE720;" FontSize="14"/>
                        </ToggleButton>
                        <ToggleButton x:Name="AudioPreviewToggle"
                                      AutomationProperties.AutomationId="AudioPreviewToggle"
                                      IsChecked="True"
                                      Width="44"
                                      Height="32"
                                      ToolTipService.ToolTip="Preview audio">
                            <FontIcon Glyph="&#xE767;" FontSize="14"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Bottom Controls Row -->
        <Grid Grid.Row="3" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Output Path and Status -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="8">
                <!-- Output Path Row -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Output"
                               FontSize="12"
                               Opacity="0.7"
                               Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="OutputPathTextBox"
                                 AutomationProperties.AutomationId="OutputPathTextBox"
                                 IsReadOnly="True"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 Height="36"
                                 Width="560"/>
                        <Button x:Name="BrowseButton"
                                AutomationProperties.AutomationId="BrowseButton"
                                Click="BrowseButton_Click"
                                Width="36"
                                Height="36"
                                Padding="0"
                                ToolTipService.ToolTip="Choose output folder">
                            <FontIcon Glyph="&#xE838;"
                                      FontSize="16"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Status Row -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEDA2;" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiskSpaceTextBlock"
                                   AutomationProperties.AutomationId="DiskSpaceTextBlock"
                                   FontSize="12"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Size:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingSizeTextBlock"
                                       AutomationProperties.AutomationId="RecordingSizeTextBlock"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MinWidth="72"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Bitrate:" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingBitrateTextBlock"
                                       AutomationProperties.AutomationId="RecordingBitrateTextBlock"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MinWidth="64"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                
            </StackPanel>

            <!-- Recording Controls -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Preview Button -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button x:Name="PreviewButton"
                            AutomationProperties.AutomationId="PreviewButton"
                            Content="Start Preview"
                            Click="PreviewButton_Click"
                            VerticalAlignment="Center"
                            Height="44"
                            MinWidth="160"
                            Padding="16,0"
                            CornerRadius="4"/>

                <!-- Record Button - transforms to show timer when recording -->
                    <Button x:Name="RecordButton"
                            AutomationProperties.AutomationId="RecordButton"
                            Click="RecordButton_Click"
                            Height="44"
                            MinWidth="160"
                            Padding="16,0"
                            Background="#E81123"
                            BorderBrush="#C50F1F"
                            CornerRadius="4">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver">#F1707A</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed">#C50F1F</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForeground">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver">White</SolidColorBrush>
                        <SolidColorBrush x:Key="ButtonForegroundPressed">White</SolidColorBrush>
                    </Button.Resources>

                    <Grid>
                        <!-- Normal state: RECORD -->
                        <StackPanel x:Name="RecordButtonNormalContent"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="White" VerticalAlignment="Center"/>
                            <TextBlock Text="RECORD"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Recording state: Timer + Stop -->
                        <StackPanel x:Name="RecordButtonRecordingContent"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="RecordingTimeTextBlock"
                                       AutomationProperties.AutomationId="RecordingTimeTextBlock"
                                       Text="00:00:00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Border Width="14" Height="14"
                                    Background="White"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                           AutomationProperties.AutomationId="StatusTextBlock"
                           Text="Ready"
                           FontSize="12"
                           Opacity="0.7"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <Expander x:Name="DiagnosticsExpander"
                  Grid.Row="4"
                  Header="Automation Diagnostics"
                  IsExpanded="False"
                  AutomationProperties.AutomationId="DiagnosticsExpander">
            <Border Margin="0,6,0,0"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid ColumnSpacing="18" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Session" FontSize="12" Opacity="0.7"/>
                    <TextBlock x:Name="DiagSessionTextBlock"
                               Grid.Row="0"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Devices" FontSize="12" Opacity="0.7"/>
                    <TextBlock x:Name="DiagDeviceTextBlock"
                               Grid.Row="1"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Capture" FontSize="12" Opacity="0.7"/>
                    <TextBlock x:Name="DiagCaptureTextBlock"
                               Grid.Row="2"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Audio/Preview" FontSize="12" Opacity="0.7"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                        <TextBlock x:Name="DiagAudioTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagPreviewTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Recording" FontSize="12" Opacity="0.7"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4">
                        <TextBlock x:Name="DiagRecordingTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagOutputTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagVerificationTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Events" FontSize="12" Opacity="0.7"/>
                    <ListView x:Name="DiagEventsListView"
                              Grid.Row="5"
                              Grid.Column="1"
                              AutomationProperties.AutomationId="DiagEventsTextBlock"
                              MaxHeight="120"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
