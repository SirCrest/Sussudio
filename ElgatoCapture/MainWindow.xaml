<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ElgatoCapture.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElgatoCapture"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Elgato Capture">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowSpacing="12">
        <Grid.Resources>
            <Storyboard x:Name="RecPulseStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="RecIndicatorDot"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.3"
                                 Duration="0:0:0.8"
                                 AutoReverse="True"/>
            </Storyboard>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Device Selection Row -->
        <Grid Grid.Row="0" ColumnSpacing="10" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Device"
                       Style="{StaticResource SecondaryLabelStyle}"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"/>

            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="Custom Audio Input"
                       Style="{StaticResource SecondaryLabelStyle}"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"/>

            <TextBlock x:Name="AudioInputLabel"
                       Grid.Row="0" Grid.Column="3"
                       Text="Audio Input"
                       Style="{StaticResource SecondaryLabelStyle}"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,2"
                       Visibility="Collapsed"/>

            <ComboBox Grid.Row="1" Grid.Column="0"
                      x:Name="DeviceComboBox"
                      AutomationProperties.AutomationId="DeviceComboBox"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      PlaceholderText="Select a capture device"/>

            <Button Grid.Row="1" Grid.Column="1"
                    x:Name="RefreshButton"
                    AutomationProperties.AutomationId="RefreshButton"
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="Refresh device list"
                    VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>

            <ToggleSwitch Grid.Row="1" Grid.Column="2"
                          x:Name="CustomAudioToggle"
                          AutomationProperties.AutomationId="CustomAudioToggle"
                          OnContent="On" OffContent="Off"
                          MinWidth="0"
                          VerticalAlignment="Center"
                          Margin="0,2,0,0"/>

            <ComboBox Grid.Row="1" Grid.Column="3"
                      x:Name="AudioInputComboBox"
                      AutomationProperties.AutomationId="AudioInputComboBox"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Name"
                      PlaceholderText="Select audio input"
                      Visibility="Collapsed"/>
        </Grid>

        <!-- Video Preview Area -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <!-- Primary GPU preview path -->
                <MediaPlayerElement x:Name="PreviewPlayerElement"
                                    AutomationProperties.AutomationId="PreviewPlayerElement"
                                    AreTransportControlsEnabled="False"
                                    AutoPlay="False"
                                    IsHitTestVisible="False"
                                    Stretch="Uniform"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />

                <!-- Fallback CPU preview path -->
                <Image x:Name="PreviewImage"
                       AutomationProperties.AutomationId="PreviewImage"
                       Stretch="Uniform"
                       Visibility="Collapsed"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

                <!-- Recording Indicator -->
                <Border x:Name="RecordingIndicator"
                        AutomationProperties.AutomationId="RecordingIndicator"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="8,4"
                        CornerRadius="4"
                        Background="{ThemeResource RecordingIndicatorBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="RecIndicatorDot" Width="10" Height="10" Fill="White"/>
                        <TextBlock Text="REC" Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- No Device Placeholder -->
                <StackPanel x:Name="NoDevicePlaceholder"
                            AutomationProperties.AutomationId="NoDevicePlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <FontIcon Glyph="&#xE714;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="No preview available"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a capture device above, then click Start Preview"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Preview Loading Overlay -->
                <StackPanel x:Name="PreviewLoadingOverlay"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <ProgressRing IsActive="True" Width="40" Height="40"/>
                    <TextBlock x:Name="PreviewLoadingText"
                               Text="Starting preview..."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings Row -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ChildrenTransitions>
                <EntranceThemeTransition/>
            </Grid.ChildrenTransitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Capture Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <!-- Resolution -->
                    <StackPanel>
                        <TextBlock Text="Resolution" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ResolutionComboBox"
                                  AutomationProperties.AutomationId="ResolutionComboBox"
                                  MinWidth="120"
                                  DisplayMemberPath="DisplayText">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                                    <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <!-- Frame Rate -->
                    <StackPanel>
                        <TextBlock Text="Frame Rate" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="HdrFpsHintTextBlock"
                                   AutomationProperties.AutomationId="HdrFpsHintTextBlock"
                                   FontSize="11"
                                   Foreground="{ThemeResource WarningHintBrush}"
                                   Opacity="0.9"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   MaxWidth="200"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="SourceTelemetryTextBlock"
                                   AutomationProperties.AutomationId="SourceTelemetryTextBlock"
                                   FontSize="11"
                                   Opacity="0.85"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   MaxWidth="220"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="TargetTelemetryTextBlock"
                                   AutomationProperties.AutomationId="TargetTelemetryTextBlock"
                                   FontSize="11"
                                   Opacity="0.8"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   MaxWidth="220"
                                   Visibility="Collapsed"/>
                        <ComboBox x:Name="FrameRateComboBox"
                                  AutomationProperties.AutomationId="FrameRateComboBox"
                                  MinWidth="90"
                                  DisplayMemberPath="DisplayText">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                                    <Setter Property="ToolTipService.ToolTip" Value="{Binding DisableReason}"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <!-- Recording Format (codec) -->
                    <StackPanel>
                        <TextBlock Text="Format" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FormatComboBox"
                                  AutomationProperties.AutomationId="FormatComboBox"
                                  MinWidth="160"/>
                    </StackPanel>

                    <!-- Quality -->
                    <StackPanel>
                        <TextBlock Text="Quality" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="QualityComboBox"
                                  AutomationProperties.AutomationId="QualityComboBox"
                                  MinWidth="100"/>
                    </StackPanel>

                    <!-- Custom Bitrate (visible only when Quality is Custom) -->
                    <StackPanel x:Name="CustomBitratePanel" Visibility="Collapsed">
                        <TextBlock Text="Bitrate" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <NumberBox x:Name="CustomBitrateNumberBox"
                                       AutomationProperties.AutomationId="CustomBitrateNumberBox"
                                       Value="50"
                                       Minimum="1"
                                       Maximum="300"
                                       SpinButtonPlacementMode="Compact"
                                       SmallChange="5"
                                       LargeChange="10"
                                       MinWidth="90"/>
                            <TextBlock Text="Mbps" VerticalAlignment="Center" Style="{StaticResource SecondaryLabelStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- HDR -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HDR" Style="{StaticResource SecondaryLabelStyle}" Margin="0,0,0,4"/>
                        <ToggleSwitch x:Name="HdrToggle"
                                      AutomationProperties.AutomationId="HdrToggle"
                                      OnContent="" OffContent=""
                                      Width="44"
                                      Height="32"
                                      MinWidth="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Audio Card -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border x:Name="AudioMeterTrack"
                                MinWidth="120" MaxWidth="300" Height="8"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource AudioMeterTrackBrush}"
                                BorderBrush="{ThemeResource AudioMeterBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Border x:Name="AudioMeterFill"
                                        CornerRadius="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#32CD32" Offset="0"/>
                                            <GradientStop Color="#32CD32" Offset="0.6"/>
                                            <GradientStop Color="#DAA520" Offset="0.75"/>
                                            <GradientStop Color="#FF8C00" Offset="0.88"/>
                                            <GradientStop Color="#FF4500" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Clip>
                                        <RectangleGeometry x:Name="AudioMeterClip" Rect="0,0,0,8"/>
                                    </Border.Clip>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="AudioClipText"
                                   AutomationProperties.AutomationId="AudioClipText"
                                   Text="CLIP"
                                   Foreground="{ThemeResource ClipAlertBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleButton x:Name="AudioRecordToggle"
                                      AutomationProperties.AutomationId="AudioRecordToggle"
                                      IsChecked="True"
                                      Width="44"
                                      Height="32"
                                      ToolTipService.ToolTip="Record audio">
                            <FontIcon Glyph="&#xE720;" FontSize="14"/>
                        </ToggleButton>
                        <ToggleButton x:Name="AudioPreviewToggle"
                                      AutomationProperties.AutomationId="AudioPreviewToggle"
                                      IsChecked="True"
                                      Width="44"
                                      Height="32"
                                      ToolTipService.ToolTip="Preview audio">
                            <FontIcon Glyph="&#xE767;" FontSize="14"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom Controls Row -->
        <Grid Grid.Row="3" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Output Path and Status -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="8">
                <!-- Output Path Row -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Output"
                               Style="{StaticResource SecondaryLabelStyle}"
                               Margin="0,0,0,2"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputPathTextBox"
                                 AutomationProperties.AutomationId="OutputPathTextBox"
                                 IsReadOnly="True"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 Height="36"/>
                        <Button x:Name="BrowseButton"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseButton"
                                Click="BrowseButton_Click"
                                Width="36"
                                Height="36"
                                Padding="0"
                                ToolTipService.ToolTip="Choose output folder">
                            <FontIcon Glyph="&#xE838;"
                                      FontSize="16"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Status Row -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEDA2;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiskSpaceTextBlock"
                                   AutomationProperties.AutomationId="DiskSpaceTextBlock"
                                   Style="{StaticResource SecondaryLabelStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Size:" Style="{StaticResource SecondaryLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingSizeTextBlock"
                                       AutomationProperties.AutomationId="RecordingSizeTextBlock"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MinWidth="72"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Bitrate:" Style="{StaticResource SecondaryLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RecordingBitrateTextBlock"
                                       AutomationProperties.AutomationId="RecordingBitrateTextBlock"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MinWidth="64"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                
            </StackPanel>

            <!-- Recording Controls -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Preview Button -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button x:Name="PreviewButton"
                            AutomationProperties.AutomationId="PreviewButton"
                            Content="Start Preview"
                            Click="PreviewButton_Click"
                            VerticalAlignment="Center"
                            Height="44"
                            MinWidth="160"
                            Padding="16,0"
                            CornerRadius="4"/>

                <!-- Record Button - transforms to show timer when recording -->
                    <Button x:Name="RecordButton"
                            AutomationProperties.AutomationId="RecordButton"
                            Click="RecordButton_Click"
                            Height="44"
                            MinWidth="160"
                            Padding="16,0"
                            Background="{ThemeResource RecordButtonBrush}"
                            BorderBrush="{ThemeResource RecordButtonBorderBrush}"
                            CornerRadius="4">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F1707A"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C50F1F"/>
                        <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>

                    <Grid>
                        <!-- Normal state: RECORD -->
                        <StackPanel x:Name="RecordButtonNormalContent"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="White" VerticalAlignment="Center"/>
                            <TextBlock Text="RECORD"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Recording state: Timer + Stop -->
                        <StackPanel x:Name="RecordButtonRecordingContent"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="RecordingTimeTextBlock"
                                       AutomationProperties.AutomationId="RecordingTimeTextBlock"
                                       Text="00:00:00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Border Width="14" Height="14"
                                    Background="White"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                           AutomationProperties.AutomationId="StatusTextBlock"
                           Text="Ready"
                           Style="{StaticResource SecondaryLabelStyle}"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="StatusInfoBar"
                 Grid.Row="4"
                 AutomationProperties.AutomationId="StatusInfoBar"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"/>

        <Expander x:Name="DiagnosticsExpander"
                  Grid.Row="5"
                  Header="Automation Diagnostics"
                  IsExpanded="False"
                  AutomationProperties.AutomationId="DiagnosticsExpander">
            <Border Margin="0,6,0,0"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid ColumnSpacing="18" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Session" Style="{StaticResource SecondaryLabelStyle}"/>
                    <TextBlock x:Name="DiagSessionTextBlock"
                               Grid.Row="0"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Devices" Style="{StaticResource SecondaryLabelStyle}"/>
                    <TextBlock x:Name="DiagDeviceTextBlock"
                               Grid.Row="1"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Capture" Style="{StaticResource SecondaryLabelStyle}"/>
                    <TextBlock x:Name="DiagCaptureTextBlock"
                               Grid.Row="2"
                               Grid.Column="1"
                               FontSize="12"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Audio/Preview" Style="{StaticResource SecondaryLabelStyle}"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                        <TextBlock x:Name="DiagAudioTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagPreviewTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Recording" Style="{StaticResource SecondaryLabelStyle}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4">
                        <TextBlock x:Name="DiagRecordingTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagOutputTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="DiagVerificationTextBlock"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Events" Style="{StaticResource SecondaryLabelStyle}"/>
                    <ListView x:Name="DiagEventsListView"
                              Grid.Row="5"
                              Grid.Column="1"
                              AutomationProperties.AutomationId="DiagEventsTextBlock"
                              MaxHeight="120"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
